# Backend configuration for AIAgentMicropayment Python API
# Copy this file to .env and update values as needed.
# If you use Infura, set WEB3_PROVIDER_URI to the Sepolia endpoint from your Infura project.
# Example: https://sepolia.infura.io/v3/your_project_id
# Do not use the Mainnet URL like https://mainnet.infura.io/v3/...

WEB3_PROVIDER_URI=
CHAIN_ID=11155111
DEFAULT_FROM_ADDRESS=
OWNER_PRIVATE_KEY=
CONTRACT_ADDRESS=
OPENAI_API_KEY=